---
import { conference } from "../data/conference";
import EmailLink from "./EmailLink.astro";
---

<footer class="border-t border-navy-100 bg-navy-50/50 mt-20">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-left">
        <p class="font-serif text-lg font-semibold text-navy-900">{conference.title}</p>
        <p class="text-sm text-navy-500 mt-1">
          {conference.location}
        </p>
        <p class="text-sm text-navy-500 mt-1">
          Questions:
          <EmailLink class="hover:text-navy-700" />
        </p>
      </div>

      <div class="flex items-center gap-5">
        <a
          href={conference.signupUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-bold tracking-wider uppercase text-navy-600 hover:text-navy-900 border border-navy-300 rounded px-3 py-1.5 transition-colors"
        >
          Conference Registration Form
        </a>
        <a
          href={conference.abstractUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-bold tracking-wider uppercase text-navy-600 hover:text-navy-900 border border-navy-300 rounded px-3 py-1.5 transition-colors"
        >
          Presentation Abstract Submission Form
        </a>
      </div>
    </div>

    <p class="text-center text-xs text-navy-400 mt-8">
      &copy; {new Date().getFullYear()} {conference.shortTitle}
    </p>
  </div>
</footer>
